<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 xmlns:vm="using:MobileVersion.ViewModels"
			 xmlns:conv="using:MobileVersion.Converters"
			 mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="800"
			 x:Class="MobileVersion.PostDetails"
			 x:DataType="vm:PostVM">
	<UserControl.Resources>
		<conv:ImageUrlToBitmapConverter x:Key="ImageUrlToBitmapConverter"/>
	</UserControl.Resources>
	<UserControl.Styles>

		<!-- Reaction pill buttons — base (overridden per-button inline) -->
		<Style Selector="Button.ReactionBtn">
			<Setter Property="BorderThickness" Value="0"/>
			<Setter Property="CornerRadius" Value="20"/>
			<Setter Property="Padding" Value="14,8"/>
			<Setter Property="FontSize" Value="13"/>
			<Setter Property="Transitions">
				<Transitions>
					<TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.12" Easing="CubicEaseOut"/>
				</Transitions>
			</Setter>
			<Setter Property="RenderTransform" Value="scale(1.0)"/>
		</Style>

		<!-- FAB -->
		<Style Selector="Button.FAB">
			<Setter Property="Width" Value="54"/>
			<Setter Property="Height" Value="54"/>
			<Setter Property="CornerRadius" Value="27"/>
			<Setter Property="Background" Value="#C0622F"/>
			<Setter Property="Foreground" Value="White"/>
			<Setter Property="FontSize" Value="26"/>
			<Setter Property="HorizontalContentAlignment" Value="Center"/>
			<Setter Property="VerticalContentAlignment" Value="Center"/>
			<Setter Property="Padding" Value="0"/>
			<Setter Property="Transitions">
				<Transitions>
					<TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.12" Easing="CubicEaseOut"/>
				</Transitions>
			</Setter>
		</Style>

		<!-- Submit button -->
		<Style Selector="Button.SubmitBtn">
			<Setter Property="Background" Value="#C0622F"/>
			<Setter Property="Foreground" Value="White"/>
			<Setter Property="CornerRadius" Value="10"/>
			<Setter Property="Padding" Value="18,8"/>
			<Setter Property="FontSize" Value="13"/>
			<Setter Property="FontWeight" Value="SemiBold"/>
			<Setter Property="BorderThickness" Value="0"/>
		</Style>

		<!-- Back button style -->
		<Style Selector="Button.BackBtn">
			<Setter Property="Background" Value="Transparent"/>
			<Setter Property="BorderThickness" Value="0"/>
			<Setter Property="Padding" Value="0"/>
			<Setter Property="RenderTransform" Value="scale(1.0)"/>
			<Setter Property="Transitions">
				<Transitions>
					<TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.12" Easing="CubicEaseOut"/>
				</Transitions>
			</Setter>
		</Style>

		<!-- Report button -->
		<Style Selector="Button.ReportBtn">
			<Setter Property="Background" Value="#8B0000"/>
			<Setter Property="Foreground" Value="#000000"/>
			<Setter Property="CornerRadius" Value="20"/>
			<Setter Property="Padding" Value="14,8"/>
			<Setter Property="FontSize" Value="13"/>
			<Setter Property="FontWeight" Value="Bold"/>
		</Style>
		<Style Selector="Button.ReportBtn:disabled /template/ ContentPresenter#PART_ContentPresenter">
			<Setter Property="Background" Value="#D0D0D0"/>
			<Setter Property="Foreground" Value="#555555"/>
		</Style>
	</UserControl.Styles>

	<!-- Root: darkened warm background -->
	<Grid Background="#B0A280" RowDefinitions="Auto, *, Auto">

		<!-- HEADER BAND -->
		<Border Grid.Row="0" ClipToBounds="True" MinHeight="120">
			<Border.Background>
				<LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
					<GradientStop Color="#7B2D0E" Offset="0"/>
					<GradientStop Color="#C0622F" Offset="0.6"/>
					<GradientStop Color="#D4834E" Offset="1"/>
				</LinearGradientBrush>
			</Border.Background>

			<Grid RowDefinitions="Auto, *" Margin="18,14,18,16">
				<Button Grid.Row="0"
						Classes="BackBtn"
						Command="{Binding CloseCommand}"
						HorizontalAlignment="Left"
						VerticalAlignment="Center">
					<Viewbox Width="22" Height="22">
						<Path Data="M20,11H7.83L13.42,5.41L12,4L4,12L12,20L13.41,18.59L7.83,13H20V11Z"
							  Fill="White"/>
					</Viewbox>
				</Button>
				<StackPanel Grid.Row="1">
					<TextBlock Text="{Binding Post.UserName}"
							   FontSize="22" FontWeight="Bold"
							   Foreground="White"
							   TextWrapping="Wrap"
							   Margin="0,10,0,0"
							   LineHeight="28"
							   HorizontalAlignment="Right"/>
					<Separator Background="#E9ECEF" Margin="0,10,0,10"/>
					<TextBlock Text="{Binding Post.Title}"
							   FontSize="22" FontWeight="Bold"
							   Foreground="White"
							   TextWrapping="Wrap"
							   Margin="0,10,0,0"
							   LineHeight="28"/>			
				</StackPanel>
			</Grid>
		</Border>

		<!-- BODY (Fixed Top, Scrollable Comments) -->
		<ScrollViewer Grid.Row="1" ScrollChanged="ScrollChanged">
		<Grid RowDefinitions="Auto, Auto, Auto, Auto, *" Name="BodyGrid">
			<!-- Article body card -->
			<Border Grid.Row="0"
					Margin="16,16,16,0"
					Background="#EDE8E0"
					CornerRadius="14"
					BoxShadow="0 2 10 0 #18000000"
					ClipToBounds="True">
				<Grid RowDefinitions="Auto, Auto" ColumnDefinitions="5, *">
					<!-- accent bar (spans both rows) -->
					<Border Grid.Row="0" Grid.RowSpan="2" Grid.Column="0" Width="5">
						<Border.Background>
							<LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
								<GradientStop Color="#C0622F" Offset="0"/>
								<GradientStop Color="#F0A868" Offset="1"/>
							</LinearGradientBrush>
						</Border.Background>
					</Border>
        
					<!-- Image (shows only if ImageUrl is not empty) -->
					<Image Grid.Row="0" Grid.Column="1"
					       Source="{Binding ImageUrl, Converter={StaticResource ImageUrlToBitmapConverter}}"
					       MaxHeight="250"
					       Stretch="Uniform"
					       HorizontalAlignment="Center"
					       Margin="14,14,14,10"/>
        
					<!-- Content text -->
					<TextBlock Grid.Row="1" Grid.Column="1"
					           Text="{Binding Post.Content}"
					           TextWrapping="Wrap"
					           FontSize="14"
					           LineHeight="22"
					           Foreground="#2C1A0E"
					           Margin="14,14,14,16"/>
				</Grid>
			</Border>

			<!-- Reaction bar -->
			<Border Grid.Row="1"
					Margin="16,10,16,0"
					Background="Transparent"
					Padding="14,10">
	
				<!-- Replaced Grid with a WrapPanel for responsive wrapping -->
				<WrapPanel Orientation="Horizontal" HorizontalAlignment="Left">
		
					<!-- Vote score badge -->
					<Border Background="Transparent" CornerRadius="10" Padding="10,6" VerticalAlignment="Center" Margin="0,0,10,10">
						<StackPanel Orientation="Horizontal" Spacing="3">
							<TextBlock Text="{Binding VoteStatus}" Foreground="#C0622F" FontSize="15" VerticalAlignment="Center"/>
							<TextBlock Text="{Binding Votes}" FontSize="15" FontWeight="Bold" Foreground="#2C1A0E" VerticalAlignment="Center"/>
						</StackPanel>
					</Border>
					
					<!-- Like -->
					<Border CornerRadius="22" BorderThickness="4" BorderBrush="{Binding Upvotecolor}" Margin="0,0,10,10">
						<Button Classes="ReactionBtn" Content="👆" Command="{Binding UpVoteCommand}" Background="Transparent" FontSize="15"/>
					</Border>
					
					<!-- Dislike -->
					<Border CornerRadius="22" BorderThickness="4" BorderBrush="{Binding Downvotecolor}" Margin="0,0,10,10">
						<Button Classes="ReactionBtn" Content="👇" Command="{Binding DownVoteCommand}" Background="Transparent" FontSize="15"/>
					</Border>
					
					<!-- Favorite -->
					<Border CornerRadius="22" BorderThickness="4" BorderBrush="{Binding Favorited}" Margin="0,0,10,10">
						<Button Classes="ReactionBtn" Content="📌" Command="{Binding FavoritingCommand}" Background="Transparent" FontSize="15"/>
					</Border>
					
					<!-- Report Button -->
					<Button Classes="ReportBtn" Command="{Binding OpenReportingCommand}" Margin="0,0,0,10" IsVisible="{Binding IsLoggedIn}" IsEnabled="{Binding NotReported}">
			<StackPanel Orientation="Horizontal" Spacing="2" HorizontalAlignment="Center">
				<TextBlock Text="🚩" FontWeight="Normal" VerticalAlignment="Center"/>
				<TextBlock Text="{Binding RepStatus}" VerticalAlignment="Center"/>
			</StackPanel>
		</Button>
		
				</WrapPanel>
			</Border>

			<!-- Report input -->
			<Border Grid.Row="2"
					IsVisible="{Binding IsReportOpen}"
					Margin="16,4,16,16"
					Background="#F8D7DA"
					CornerRadius="14"
					BoxShadow="0 2 10 0 #18000000"
					Padding="14,12">
				<StackPanel Spacing="10">
					<TextBlock Text="Report this post" FontSize="11" FontWeight="SemiBold" Foreground="#842029" LetterSpacing="0.8"/>
					<TextBox Text="{Binding ReportReason}" Watermark="Why are you reporting this?..." TextWrapping="Wrap" AcceptsReturn="True" MinHeight="60" CornerRadius="8" BorderBrush="#F1B8BC" BorderThickness="1"/>
					<Button Content="Submit Report" Classes="SubmitBtn" Background="#842029" Command="{Binding ReportCommand}" HorizontalAlignment="Right"/>
				</StackPanel>
			</Border>

			<!-- Comments heading -->
			<StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="8" Margin="20,18,16,8">
				<TextBlock Text="💬" FontSize="14" FontWeight="Normal"/>
				<TextBlock Text="COMMENTS" FontSize="10" FontWeight="Bold" Foreground="#8A6040" LetterSpacing="1.5" VerticalAlignment="Center"/>
			</StackPanel>

			<!-- Comment input -->


			<!-- SCROLLABLE Comment bubbles -->
			<ScrollViewer Grid.Row="4" Name="CommentScroller">
				<StackPanel>
					<Border IsVisible="{Binding IsCommentingOpen}"
							Margin="16,4,16,16"
							Background="#EDE8E0"
							CornerRadius="14"
							BoxShadow="0 2 10 0 #18000000"
							Padding="14,12"
							Name="CommentBorder">
						<StackPanel Spacing="10">
							<TextBlock Text="Write a reply" FontSize="11" FontWeight="SemiBold" Foreground="#8A6040" LetterSpacing="0.8"/>
							<TextBox Text="{Binding CommentText}" Watermark="Share your thoughts..." TextWrapping="Wrap" AcceptsReturn="True" MinHeight="80" CornerRadius="8" BorderBrush="#C8B8A8" BorderThickness="1"/>
							<Button Content="Post reply" Classes="SubmitBtn" Command="{Binding CommentingCommand}" HorizontalAlignment="Right"/>
						</StackPanel>
					</Border>
					<ItemsControl ItemsSource="{Binding DisplayComments}" Margin="16,0,16,0">
						<ItemsControl.ItemTemplate>
							<DataTemplate>
								<Border Background="#EDE8E0"
										CornerRadius="12"
										BoxShadow="0 1 6 0 #12000000"
										Padding="12,10"
										Margin="0,0,0,8">
									<Grid ColumnDefinitions="Auto, *">
										<Border Grid.Column="0" Width="34" Height="34" CornerRadius="17" Margin="0,0,10,0" VerticalAlignment="Top">
											<Border.Background>
												<LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
													<GradientStop Color="#C0622F" Offset="0"/>
													<GradientStop Color="#F0A868" Offset="1"/>
												</LinearGradientBrush>
											</Border.Background>
											<TextBlock Text="{Binding username[0]}" Foreground="White" FontWeight="Bold" FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center"/>
										</Border>
										<StackPanel Grid.Column="1" Spacing="3">
											<StackPanel Orientation="Horizontal" Spacing="8">
												<TextBlock Text="{Binding username}" FontWeight="SemiBold" FontSize="13" Foreground="#2C1A0E"/>
												<TextBlock Text="{Binding commentcreated_at}" FontSize="10" Foreground="#9A7050" VerticalAlignment="Center"/>
											</StackPanel>
											<TextBlock Text="{Binding commentcontent}" TextWrapping="Wrap" FontSize="13" LineHeight="19" Foreground="#4A3020"/>
										</StackPanel>
									</Grid>
								</Border>
							</DataTemplate>
						</ItemsControl.ItemTemplate>
					</ItemsControl>
					<Border Height="80"/> <!-- Allows pulling comments up out of the way of the FAB -->
				</StackPanel>
			</ScrollViewer>
		</Grid>
		</ScrollViewer>
		<!-- Bottom rule -->
		<Border Grid.Row="2" Height="1">
			<Border.Background>
				<LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,0%">
					<GradientStop Color="#00C8B8A8" Offset="0"/>
					<GradientStop Color="#C8B8A8" Offset="0.5"/>
					<GradientStop Color="#00C8B8A8" Offset="1"/>
				</LinearGradientBrush>
			</Border.Background>
		</Border>

		<!-- FAB -->
		<Button Grid.Row="1"
				Classes="FAB"
				Content="+"
				Command="{Binding OpenCommentingCommand}"
				Click="ToTop_OnClick"
				IsVisible="{Binding IsLoggedIn}"
				HorizontalAlignment="Right"
				VerticalAlignment="Bottom"
				Margin="20"/>

	</Grid>
</UserControl>