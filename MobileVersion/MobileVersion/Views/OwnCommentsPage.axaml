<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:MobileVersion.ViewModels"
             xmlns:dto="using:MobileVersion.Dtos"
             mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="700"
             x:Class="MobileVersion.OwnCommentsPage"
             x:DataType="vm:OwnCommentsVM">

    <!-- UNIQUE ABYSSAL INDIGO BACKGROUND -->
    <UserControl.Background>
        <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
            <GradientStop Offset="0.0" Color="#1E1E2E" />
            <GradientStop Offset="1.0" Color="#11111B" />
        </LinearGradientBrush>
    </UserControl.Background>

    <UserControl.Styles>
        <!-- Modern "Bubble" Comment Style -->
        <Style Selector="Border.CommentCard">
            <Setter Property="Background" Value="#1E1E2E"/>
            <Setter Property="BorderBrush" Value="#313244"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="18"/>
            <Setter Property="RenderTransform" Value="translateX(0px)"/>
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.2"/>
                    <BrushTransition Property="BorderBrush" Duration="0:0:0.2"/>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.2" Easing="CubicEaseOut"/>
                </Transitions>
            </Setter>
        </Style>

    </UserControl.Styles>

    <Grid RowDefinitions="Auto, *">
        <!-- MINIMALIST HEADER -->
        <Border Grid.Row="0" Padding="20" Background="Transparent">
            <Grid ColumnDefinitions="Auto, *">
                <Button Command="{Binding CloseCommand}" 
                        Background="#313244" 
                        CornerRadius="12"
                        Width="40" Height="40"
                        Padding="0">
                    <Path Data="M20,11V13H8L13.5,18.5L12.08,19.92L4.16,12L12.08,4.08L13.5,5.5L8,11H20Z" 
                          Fill="#CBA6F7" 
                          Width="18" Height="18"
                          Stretch="Uniform" 
                          VerticalAlignment="Center"
                          HorizontalAlignment="Center"/>
                </Button>

                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="20,0">
                    <TextBlock Text="TIMELINE" FontSize="11" FontWeight="Heavy" Foreground="#6C7086" LetterSpacing="3"/>
                    <TextBlock Text="{Binding Username}" FontSize="24" FontWeight="SemiBold" Foreground="#CDD6F4"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- COMMENTS LIST -->
        <ScrollViewer Grid.Row="1" Name="PostsScroller" ScrollChanged="ScrollChanged">
            <ItemsControl ItemsSource="{Binding OwnComms}" Margin="20,10">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:PostVM">
                        
                        <!-- INNER LOOP: Iterates through all comments on THIS post -->
                        <ItemsControl ItemsSource="{Binding UserOwnComments}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="dto:OwnComments">
                                    
                                    <!-- The button clicks "up" to the PostVM's SelectCommand -->
                                    <Button Command="{Binding $parent[ItemsControl].((vm:PostVM)DataContext).SelectCommand}" 
                                            Background="Transparent" 
                                            Padding="0" Margin="0,0,0,15"
                                            HorizontalAlignment="Stretch"
                                            HorizontalContentAlignment="Stretch">
                                        
                                        <Border Classes="CommentCard" Padding="20">
                                            <StackPanel Spacing="12">
                                                <Grid ColumnDefinitions="Auto, *">
                                                    <Ellipse Width="8" Height="8" Fill="#CBA6F7" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                                    <TextBlock Grid.Column="1"
                                                               Text="{Binding CommentCreated_at, StringFormat='{}Logged on {0:MMM dd, HH:mm}'}"
                                                               FontSize="11" Foreground="#9399B2" VerticalAlignment="Center"/>
                                                </Grid>

                                                <!-- Binds directly to the OwnComments DTO properties -->
                                                <TextBlock Text="{Binding CommentContent}" 
                                                           FontSize="15" Foreground="#CDD6F4" 
                                                           TextWrapping="Wrap" LineHeight="24"/>
                                                
                                                <Border Height="1" Background="#313244" Opacity="0.5"/>
                                            </StackPanel>
                                        </Border>
                                    </Button>
                                    
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>
