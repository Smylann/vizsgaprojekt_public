<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:MobileVersion.ViewModels"
             mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="700"
             x:Class="MobileVersion.FavoritePostsPage"
             x:DataType="vm:FavoritePostsVM">

    <!-- UNIQUE SUNSET GRADIENT BACKGROUND -->
    <UserControl.Background>
        <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
            <GradientStop Offset="0.0" Color="#434343" />
            <GradientStop Offset="1.0" Color="#000000" />
        </LinearGradientBrush>
    </UserControl.Background>

    <UserControl.Styles>
        <!-- Specialized "Favorite" Card Style -->
        <Style Selector="Border.FavCard">
            <Setter Property="Background" Value="#1AFFFFFF"/>
            <Setter Property="BorderBrush" Value="#20FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BoxShadow" Value="0 8 20 0 #40000000"/>
            <Setter Property="Transitions">
                <Transitions>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.25" Easing="BackEaseOut"/>
                    <BrushTransition Property="Background" Duration="0:0:0.2"/>
                </Transitions>
            </Setter>
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto, *">
        <!-- ELEGANT HEADER -->
        <Border Grid.Row="0" Padding="20" Background="#10000000">
            <Grid ColumnDefinitions="Auto, *">
                <Button Grid.Column="0" 
                        Command="{Binding CloseCommand}" 
                        Background="Transparent" 
                        BorderThickness="0"
                        Width="40" Height="40">
                    <Path Data="M20,11V13H8L13.5,18.5L12.08,19.92L4.16,12L12.08,4.08L13.5,5.5L8,11H20Z" 
                          Fill="#FFD700" 
                          Stretch="Uniform"/>
                </Button>
                
                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="15,0">
                    <TextBlock Text="COLLECTION" 
                               FontSize="10" 
                               FontWeight="Heavy" 
                               Foreground="#80FFD700" 
                               LetterSpacing="3"/>
                    <TextBlock Text="{Binding Username}" 
                               FontSize="22" 
                               FontWeight="Thin" 
                               Foreground="White"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- FAVORITE LIST -->
        <ScrollViewer Grid.Row="1" Name="PostsScroller" ScrollChanged="ScrollChanged">
            <ItemsControl ItemsSource="{Binding FavoritePosts}" Margin="20">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:PostVM">
                        <Button Classes="CardWrapper" 
                                Background="Transparent" 
                                Padding="0" 
                                BorderThickness="0"
                                HorizontalAlignment="Stretch"
                                Command="{Binding SelectCommand}">
                            <Border Classes="FavCard" 
                                    Margin="0,0,0,20" 
                                    Padding="15" 
                                    CornerRadius="20">
                                <Grid ColumnDefinitions="*, Auto"> 
                                    <StackPanel Grid.Column="0" Spacing="6">
                                        <!-- Star uses the specific color override class -->
                                        <StackPanel Orientation="Horizontal" Spacing="4" Margin="0,0,0,2">
                                            <TextBlock Text="★" Classes="FavHeading" FontSize="13" FontWeight="Normal" VerticalAlignment="Center"/>
                                            <TextBlock Text="FAVORITE" Classes="FavHeading" FontSize="9" FontWeight="Bold" VerticalAlignment="Center"  Foreground="White"/>
                                        </StackPanel>
                                        
                                        <TextBlock Text="{Binding Post.Title}" 
                                                   FontWeight="SemiBold" 
                                                   FontSize="18"
                                                   Foreground="White"/>
                                        
                                        <TextBlock Text="{Binding Post.Content}"
                                                   TextWrapping="Wrap" 
                                                   MaxLines="2"
                                                   Opacity="0.7" 
                                                   FontSize="13"
                                                   FontStyle="Italic"
                                                   Foreground="White"/>

                                        <StackPanel Orientation="Horizontal" Margin="0,5,0,0" Spacing="10">
                                            <TextBlock Text="🔥" FontWeight="Normal" FontSize="11" Foreground="#FFD700" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding Votes}" FontSize="11" Foreground="#FFD700" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </StackPanel>
                                    
                                    <!-- Decorative Star emoji -->
                                    <TextBlock Grid.Column="1" 
                                               Text="✪" 
                                               FontSize="24" 
                                               FontWeight="Normal"
                                               Foreground="#30FFD700" 
                                               VerticalAlignment="Top"/>
                                </Grid>
                            </Border>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>
